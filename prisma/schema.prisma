generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Airplane {
  id          Int      @id @default(autoincrement())
  modelNumber String   @map("model_number")
  capacity    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  flights     Flight[]

  @@map("airplanes")
}

model City {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(50)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  airports  Airport[]

  @@map("cities")
}

model Airport {
  id               Int      @id @default(autoincrement())
  name             String   @unique @db.VarChar(100)
  code             String   @unique @db.VarChar(20)
  address          String?
  cityId           Int      @map("city_id")
  city             City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  departureFlights Flight[] @relation("DepartureFlights")
  arrivalFlights   Flight[] @relation("ArrivalFlights")

  @@map("airports")
}

model Flight {
  id                 Int      @id @default(autoincrement())
  flightNumber       String   @map("flight_number") @db.VarChar(20)
  airplaneId         Int      @map("airplane_id")
  departureAirportId String   @map("departure_airport_id")
  arrivalAirportId   String   @map("arrival_airport_id")
  departureTime      DateTime @map("departure_time")
  arrivalTime        DateTime @map("arrival_time")
  price              Int
  boardingGate       String?  @map("boarding_gate")
  totalSeats         Int      @map("total_seats")

  // Relation
  airplane         Airplane @relation(fields: [airplaneId], references: [id])
  departureAirport Airport  @relation("DepartureFlights", fields: [departureAirportId], references: [code], onDelete: Cascade)
  arrivalAirport   Airport  @relation("ArrivalFlights", fields: [arrivalAirportId], references: [code], onDelete: Cascade)

  @@map("flights")
}
